<mujoco model="piper_x">
  <!-- PiPER-X: AgileX 6-DOF arm + coupled parallel gripper.
       Body tree, inertials and joint frames converted from the piper-x-arm
       submodule's URDF (external/piper-x-arm/assets/piper_x/urdf/piper_x.urdf)
       via MuJoCo's URDF importer (see scratchpad/convert_phase1.py). Meshes are
       sourced directly from that submodule (meshdir below) - the .stl meshes
       serve as both visual and collision geometry, since MuJoCo cannot load the
       .dae visual meshes. Per-link material colors were recovered from the .dae
       materials (dark charcoal plastic, lighter forearm links, no image
       textures). Manipulation infrastructure (actuators, coupled gripper
       equality, grasp_site TCP, cameras) added by hand, modelled on i2rt YAM. -->
  <compiler angle="radian" meshdir="../../external/piper-x-arm/assets/piper_x/meshes" autolimits="true"/>

  <option integrator="implicitfast"/>

  <size nkey="1"/>

  <default>
    <default class="piper_x">
      <joint frictionloss="0.1" armature="0.01"/>
      <!-- affine position servo: gainprm=kp, biasprm="0 -kp -kv" -->
      <general biastype="affine" gainprm="150" biasprm="0 -150 -15" forcerange="-100 100"/>
      <default class="wrist">
        <general gainprm="60" biasprm="0 -60 -6" forcerange="-30 30"/>
      </default>
      <default class="finger">
        <joint armature="0.1"/>
        <general ctrlrange="0 0.05" gainprm="200" biasprm="0 -200 -20" forcerange="-40 40"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2" density="0"/>
      </default>
      <default class="collision">
        <geom type="mesh" contype="1" conaffinity="1" group="3"/>
      </default>
    </default>
  </default>

  <asset>
    <!-- per-link colors recovered from the .dae materials (area-weighted dominant) -->
    <material name="piper_dark" rgba="0.12 0.12 0.12 1" specular="0.35" shininess="0.35"/>
    <material name="piper_mid" rgba="0.26 0.26 0.26 1" specular="0.4" shininess="0.4"/>
    <material name="piper_grip" rgba="0.18 0.18 0.18 1" specular="0.3" shininess="0.3"/>

    <mesh name="base_link" file="base_link.stl"/>
    <mesh name="link1" file="link1.stl"/>
    <mesh name="link2" file="link2.stl"/>
    <mesh name="link3" file="link3.stl"/>
    <mesh name="link4" file="link4.stl"/>
    <mesh name="link5" file="link5.stl"/>
    <mesh name="link6" file="link6.stl"/>
    <mesh name="gripper_base" file="gripper_base.stl"/>
    <mesh name="gripper_link1" file="gripper_link1.stl"/>
    <mesh name="gripper_link2" file="gripper_link2.stl"/>
  </asset>

  <worldbody>
    <body name="base_link" childclass="piper_x">
      <inertial pos="-0.00473641 2.56829e-05 0.0414515" quat="0.70428 0.034288 0.0339756 0.708279" mass="1.02" diaginertia="0.00282612 0.00269117 0.000879394"/>
      <geom class="visual" mesh="base_link" material="piper_dark"/>
      <geom class="collision" mesh="base_link"/>
      <!-- exocentric camera on the fixed base, auto-aimed at the mid-arm -->
      <camera name="exo_camera" pos="-0.35 0.35 0.55" mode="targetbody" target="link3" fovy="58"/>
      <body name="link1" pos="0 0 0.123" quat="2.67949e-08 0 0 1">
        <inertial pos="0.00053 -0.00039 -0.00315" quat="0.737007 0.671914 -0.0484837 0.0547877" mass="0.71" diaginertia="0.0005012 0.00045752 0.00040836"/>
        <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-2.61799 2.61799"/>
        <geom class="visual" mesh="link1" material="piper_dark"/>
        <geom class="collision" mesh="link1"/>
        <body name="link2" quat="-0.705478 -0.705478 0.0479709 -0.047971">
          <inertial pos="0.21856 -0.00859 0.00227" quat="0.479919 0.532436 0.466857 0.517913" mass="1.16" diaginertia="0.0676841 0.0675582 0.00106833"/>
          <joint name="joint2" pos="0 0 0" axis="0 0 1" range="0 3.14159"/>
          <geom class="visual" mesh="link2" material="piper_mid"/>
          <geom class="collision" mesh="link2"/>
          <body name="link3" pos="0.28503 0 0" quat="0.151175 0 0 0.988507">
            <inertial pos="0.2014 -0.00418 -0.00141" quat="0.489607 0.514215 0.487521 0.508126" mass="0.67" diaginertia="0.0336064 0.0335699 0.000331954"/>
            <joint name="joint3" pos="0 0 0" axis="0 0 1" range="-2.96706 0"/>
            <geom class="visual" mesh="link3" material="piper_mid"/>
            <geom class="collision" mesh="link3"/>
            <body name="link4" pos="0.27364 0 0" quat="0.999187 0 0 0.0403062">
              <inertial pos="0.059 -0.05831 0.002" quat="0.564777 0.676972 0.20773 0.423773" mass="0.39" diaginertia="0.00310241 0.00307501 0.000195685"/>
              <joint name="joint4" class="wrist" pos="0 0 0" axis="0 0 1" range="-1.55334 1.55334"/>
              <geom class="visual" mesh="link4" material="piper_dark"/>
              <geom class="collision" mesh="link4"/>
              <body name="link5" pos="0.07466 0 0" quat="0.5 -0.5 0.5 0.5">
                <inertial pos="5e-05 -0.01282 -0.00429" quat="0.724649 0.689115 0.000743367 0.00197726" mass="0.35" diaginertia="0.000226601 0.000194293 0.000177357"/>
                <joint name="joint5" class="wrist" pos="0 0 0" axis="0 0 1" range="-1.55334 1.55334"/>
                <geom class="visual" mesh="link5" material="piper_dark"/>
                <geom class="collision" mesh="link5"/>
                <body name="link6" pos="0 -0.035 0" quat="0.707107 0.707107 0 0">
                  <inertial pos="0 0 -0.0035" quat="0.999971 -8.01245e-07 -0.00107878 0.00748677" mass="0.007" diaginertia="0.00152116 0.00138623 0.000311514"/>
                  <joint name="joint6" class="wrist" pos="0 0 0" axis="0 0 1" range="-2.0944 2.0944"/>
                  <geom class="visual" mesh="link6" material="piper_dark"/>
                  <geom class="collision" mesh="link6"/>
                  <body name="gripper_base" quat="0.707107 0 0 0.707107">
                    <inertial pos="-0.000183807 8.05033e-05 0.0321437" quat="0.999976 9.08444e-05 0.00689649 0.000788512" mass="0.45" diaginertia="0.000929442 0.000714469 0.000394318"/>
                    <geom class="visual" mesh="gripper_base" material="piper_grip"/>
                    <geom class="collision" mesh="gripper_base"/>
                    <!-- TCP: +z = approach axis, ~14cm out from gripper_base (matches prior cuRobo EE_TCP_OFFSET) -->
                    <site name="tcp_site" pos="0 0 0.14" quat="1 0 0 0" group="4" rgba="1 0 0 1" size="0.005"/>
                    <site name="grasp_site" pos="0 0 0.14" quat="1 0 0 0" group="4" rgba="0 1 0 1" size="0.005"/>
                    <!-- Orbbec DC1 wrist cam on the printed mount. Pose derived from the
                         piper-x-arm CAD source of truth (cad/models/arm/wrist_cam_mount.scad
                         via preview_mount.cam_local_transform), converted to MuJoCo camera
                         convention. fovy from the DC1 color intrinsics (fy=486.64, h=480). -->
                    <camera name="wrist_camera" pos="-0.07534 0 0.04964"
                            quat="-0.190415 0.680986 0.680986 -0.190415" fovy="52.5"/>
                    <body name="gripper_link1" pos="0 0 0.1358" quat="0.707107 0.707107 0 0">
                      <inertial pos="0.000651232 -0.049193 0.00972259" quat="0.477798 0.572974 -0.518028 0.418398" mass="0.025" diaginertia="7.74531e-05 7.36783e-05 5.0886e-06"/>
                      <joint name="gripper_joint1" class="finger" pos="0 0 0" axis="0 0 1" type="slide" range="0 0.05"/>
                      <geom class="visual" mesh="gripper_link1" material="piper_dark"/>
                      <geom class="collision" mesh="gripper_link1"/>
                    </body>
                    <body name="gripper_link2" pos="0 0 0.1358" quat="1.89469e-08 1.89469e-08 -0.707107 -0.707107">
                      <inertial pos="0.000651232 -0.049193 0.00972259" quat="0.477798 0.572974 -0.518028 0.418398" mass="0.025" diaginertia="7.74531e-05 7.36783e-05 5.0886e-06"/>
                      <joint name="gripper_joint2" class="finger" pos="0 0 0" axis="0 0 -1" type="slide" range="-0.05 0"/>
                      <geom class="visual" mesh="gripper_link2" material="piper_dark"/>
                      <geom class="collision" mesh="gripper_link2"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <!-- fingers are siblings (not parent-child), so exclude their mutual contact -->
    <exclude body1="gripper_link1" body2="gripper_link2"/>
  </contact>

  <equality>
    <!-- couple the parallel gripper: gripper_joint2 = -gripper_joint1 -->
    <joint joint1="gripper_joint2" joint2="gripper_joint1" polycoef="0 -1 0 0 0"/>
  </equality>

  <actuator>
    <general name="joint1" joint="joint1" ctrlrange="-2.61799 2.61799"/>
    <general name="joint2" joint="joint2" ctrlrange="0 3.14159"/>
    <general name="joint3" joint="joint3" ctrlrange="-2.96706 0"/>
    <general name="joint4" class="wrist" joint="joint4" ctrlrange="-1.55334 1.55334"/>
    <general name="joint5" class="wrist" joint="joint5" ctrlrange="-1.55334 1.55334"/>
    <general name="joint6" class="wrist" joint="joint6" ctrlrange="-2.0944 2.0944"/>
    <!-- single actuator drives gripper_joint1; gripper_joint2 follows via equality -->
    <general name="gripper" class="finger" joint="gripper_joint1"/>
  </actuator>

  <keyframe>
    <!-- home: arm folded up out of singularity, gripper open -->
    <key name="home" qpos="0 1.2 -1.2 0 0.6 0 0.05 -0.05" ctrl="0 1.2 -1.2 0 0.6 0 0.05"/>
  </keyframe>
</mujoco>
